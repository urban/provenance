{
  "name": "@urban/provenance-mono",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "bun run --filter './apps/*' build",
    "check": "bun run lint && bun run --workspaces typecheck && bun run --workspaces test",
    "lint": "oxfmt && oxlint --fix",
    "test": "bun run --workspaces test",
    "typecheck": "bun run --workspaces typecheck"
  },
  "devDependencies": {
    "@changesets/cli": "2.30.0",
    "@effect/language-service": "^0.84.0",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "oxfmt": "0.43.0",
    "oxlint": "1.58.0",
    "typescript": "latest"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "oxfmt",
      "oxlint --fix"
    ],
    "*.{css,html,json,jsonc,md,mdx,yml,yaml}": [
      "oxfmt"
    ]
  },
  "engines": {
    "node": ">= 24.12.0"
  },
  "packageManager": "bun@1.3.5"
}
